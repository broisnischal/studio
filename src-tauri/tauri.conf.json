{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "db-studio",
  "version": "0.1.15",
  "identifier": "com.broisnischal.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMjlCQUIyQjA3Qjg4MjYKUldRbWlIdXdzcm9wbnlqVXRHc3lwWHRWdHVkdmFoMjZhM1lQZ3BnM1Ird0hlYXBxZWo5b1dLV3QK",
      "endpoints": [
        "https://github.com/broisnischal/studio/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
