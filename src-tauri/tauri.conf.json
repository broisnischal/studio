{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "db-studio",
  "version": "0.1.5",
  "identifier": "com.broisnischal.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5NDM4RjkyM0Q0MzE2RjIKUldUeUZrTTlrbzlEYVRYVmFnTWJmem95cFJVaHo5VHJJSW1ZaldHN2FQZ1NqWEdUTWo0NE5vY3IK",
      "endpoints": [
        "https://github.com/broisnischal/studio/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
